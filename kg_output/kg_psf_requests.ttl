node:7a414bb0 a kg:Method ;
    rdfs:label "validate_access_token" ;
    kg:branches 0 ;
    kg:className "Server" ;
    kg:docstring """Validates that supplied access token is registered and valid.

        Note that if the dummy access token is supplied it should validate in
        the same or nearly the same amount of time as a valid one.

        Bad:

            if access_token == self.dummy_access_token:
                return False
            else:
                return storage.has_access_token(access_token)

        Good:

            return (storage.has_access_token(access_token) and
                    access_token != self.dummy_access_token)""" ;
    kg:filepath "requests/packages/oauthlib/oauth1/rfc5849/__init__.py" ;
    kg:isAsync false ;
    kg:lineno 528 ;
    kg:param [ kg:paramName "self" ],
        [ kg:paramName "client_key" ],
        [ kg:paramName "access_token" ] ;
    kg:raises "NotImplementedError('Subclasses must implement this function.')" ;
    kg:repo "psf/requests" .

