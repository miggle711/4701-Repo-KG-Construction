node:040da946 a kg:Function ;
    rdfs:label "split_first" ;
    kg:branches 4 ;
    kg:docstring """Given a string and an iterable of delimiters, split on the first found
    delimiter. Return two split parts and the matched delimiter.

    If not found, then the first part is the full input string.

    Example: ::

        >>> split_first('foo/bar?baz', '?/=')
        ('foo', 'bar?baz', '/')
        >>> split_first('foo/bar?baz', '123')
        ('foo/bar?baz', '', None)

    Scales linearly with number of delims. Not ideal for large number of delims.""" ;
    kg:filepath "requests/packages/urllib3/util.py" ;
    kg:isAsync false ;
    kg:lineno 51 ;
    kg:param [ kg:paramName "s" ],
        [ kg:paramName "delims" ] ;
    kg:repo "psf/requests" .

