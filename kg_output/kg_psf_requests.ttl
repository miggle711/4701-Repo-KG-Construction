node:1bf4ee00 a kg:Class ;
    rdfs:label "RequestsCookieJar" ;
    kg:contains node:03401111,
        node:264265e0,
        node:3aa72053,
        node:47b12755,
        node:6e828193,
        node:963e874a,
        node:9882acaa,
        node:988bd547,
        node:a3bc7fa1,
        node:c6ffa2a0,
        node:c987c034,
        node:db3f4dd5,
        node:e0f8034c,
        node:e71fe981,
        node:e7f36cfa,
        node:ed6ca4df,
        node:fa5bf36a ;
    kg:docstring """Compatibility class; is a cookielib.CookieJar, but exposes a dict interface.

    This is the CookieJar we create by default for requests and sessions that
    don't specify one, since some clients may expect response.cookies and
    session.cookies to support dict operations.

    Don't use the dict interface internally; it's just for compatibility with
    with external client code. All `requests` code should work out of the box
    with externally provided instances of CookieJar, e.g., LWPCookieJar and
    FileCookieJar.

    Caution: dictionary operations that are normally O(1) may be O(n).

    Unlike a regular CookieJar, this class is pickleable.""" ;
    kg:filepath "requests/cookies.py" ;
    kg:lineno 134 ;
    kg:repo "psf/requests" ;
    kg:uses node:296e05a3 .

