node:664d4d1e a kg:Function ;
    rdfs:label "parse_url" ;
    kg:branches 11 ;
    kg:calls node:040da946 ;
    kg:depends_on node:68926771 ;
    kg:docstring """Given a url, return a parsed :class:`.Url` namedtuple. Best-effort is
    performed to parse incomplete urls. Fields not provided will be None.

    Partly backwards-compatible with :mod:`urlparse`.

    Example: ::

        >>> parse_url('http://google.com/mail/')
        Url(scheme='http', host='google.com', port=None, path='/', ...)
        >>> prase_url('google.com:80')
        Url(scheme=None, host='google.com', port=80, path=None, ...)
        >>> prase_url('/foo?bar')
        Url(scheme=None, host=None, port=None, path='/foo', query='bar', ...)""" ;
    kg:filepath "requests/packages/urllib3/util.py" ;
    kg:isAsync false ;
    kg:lineno 84 ;
    kg:param [ kg:paramName "url" ] ;
    kg:raises "LocationParseError('Failed to parse: %s' % url)" ;
    kg:repo "psf/requests" .

