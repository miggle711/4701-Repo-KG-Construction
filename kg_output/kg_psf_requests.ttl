node:9d2e5da1 a kg:Function ;
    rdfs:label "parse_dict_header" ;
    kg:branches 3 ;
    kg:calls node:987974a7 ;
    kg:depends_on node:52e3eaf7 ;
    kg:docstring """Parse lists of key, value pairs as described by RFC 2068 Section 2 and
    convert them into a python dict:

    >>> d = parse_dict_header('foo="is a fish", bar="as well"')
    >>> type(d) is dict
    True
    >>> sorted(d.items())
    [('bar', 'as well'), ('foo', 'is a fish')]

    If there is no value for a key it will be `None`:

    >>> parse_dict_header('key_without_value')
    {'key_without_value': None}

    To create a header from the :class:`dict` again, use the
    :func:`dump_header` function.

    :param value: a string with a dict header.
    :return: :class:`dict`""" ;
    kg:filepath "requests/utils.py" ;
    kg:isAsync false ;
    kg:lineno 197 ;
    kg:param [ kg:paramName "value" ] ;
    kg:repo "psf/requests" .

