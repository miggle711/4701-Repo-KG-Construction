        node:9882acaa,
        node:d5541a60,
        node:e7f85949 ;
    kg:docstring """Verify that *cert* (in decoded format as returned by
    SSLSocket.getpeercert()) matches the *hostname*.  RFC 2818 rules
    are mostly followed, but IP addresses are not accepted for *hostname*.

    CertificateError is raised on failure. On success, the function
    returns nothing.""" ;
    kg:filepath "requests/packages/urllib3/packages/ssl_match_hostname/__init__.py" ;
    kg:isAsync false ;
    kg:lineno 23 ;
    kg:param [ kg:paramName "cert" ],
        [ kg:paramName "hostname" ] ;
    kg:raises "CertificateError(\"hostname %r doesn't match %r\" % (hostname, dnsnames[0]))",
