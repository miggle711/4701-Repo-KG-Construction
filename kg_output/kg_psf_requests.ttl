        [ kg:paramName "url" ],
        [ kg:paramName "**urlopen_kw" ] ;
    kg:repo "psf/requests" .

node:274edf9f a kg:Method ;
    rdfs:label "urlopen" ;
    kg:branches 10 ;
    kg:calls node:068cb95a,
        node:161be677,
        node:274edf9f,
        node:36641af6,
        node:401e4c5f,
