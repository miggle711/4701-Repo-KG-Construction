node:2a05226f a kg:Class ;
    rdfs:label "PoolManager" ;
    kg:contains node:1f287cd9,
        node:80b17084,
        node:9c660188,
        node:a01e9d5b,
        node:d7781d70 ;
    kg:docstring """Allows for arbitrary requests while transparently keeping track of
    necessary connection pools for you.

    :param num_pools:
        Number of connection pools to cache before discarding the least recently
        used pool.

    :param \\**connection_pool_kw:
        Additional parameters are used to create fresh
        :class:`urllib3.connectionpool.ConnectionPool` instances.

    Example: ::

        >>> manager = PoolManager(num_pools=2)
        >>> r = manager.urlopen("http://google.com/")
        >>> r = manager.urlopen("http://google.com/mail")
        >>> r = manager.urlopen("http://yahoo.com/")
        >>> len(manager.pools)
        2""" ;
    kg:filepath "requests/packages/urllib3/poolmanager.py" ;
    kg:inherits node:2772c8e7 ;
    kg:lineno 27 ;
    kg:repo "psf/requests" ;
    kg:uses node:4404b210 .

