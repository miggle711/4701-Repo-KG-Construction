node:a7a5ff42 a kg:Function ;
    rdfs:label "normalize_base_string_uri" ;
    kg:branches 3 ;
    kg:depends_on node:745b45c6 ;
    kg:docstring """**Base String URI**
    Per `section 3.4.1.2`_ of the spec.

    For example, the HTTP request::

        GET /r%20v/X?id=123 HTTP/1.1
        Host: EXAMPLE.COM:80

    is represented by the base string URI: "http://example.com/r%20v/X".

    In another example, the HTTPS request::

        GET /?q=1 HTTP/1.1
        Host: www.example.net:8080

    is represented by the base string URI: "https://www.example.net:8080/".

    .. _`section 3.4.1.2`: http://tools.ietf.org/html/rfc5849#section-3.4.1.2""" ;
    kg:filepath "requests/packages/oauthlib/oauth1/rfc5849/signature.py" ;
    kg:isAsync false ;
    kg:lineno 98 ;
    kg:param [ kg:paramName "uri" ] ;
    kg:raises "ValueError('uri must be a unicode object.')" ;
    kg:repo "psf/requests" .

